{{ define "head" -}}
<title>git-credential-oauth-generic: {{ .Title }}</title>
<meta name="color-scheme" content="light dark"/>
<style>
	body {
        font-family: sans-serif;
        max-width: 600px;
        margin: 2em auto;
        padding: 0 1em;
        user-select: none;
    }
	.url-box {
        background: #f4f4f4;
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 0.75em;
        word-break: break-all;
        font-family: monospace;
        font-size: 0.85em;
        margin: 1em 0;
        user-select: text;
    }
	@media (prefers-color-scheme: dark) {
        .url-box {
            background: #2a2a2a;
            border-color: #555;
        }
    }
	.continue {
        display: inline-block;
        margin-top: 0.5em;
        padding: 0.5em 1.5em;
        background: #0070f3;
        color: white;
        text-decoration: none;
        border-radius: 4px;
    }
	.continue:hover {
        background: #005bb5;
    }
</style>
{{- end }}
{{ define "page" -}}
<!DOCTYPE html>
<html lang="en">
<head>
{{ template "head" . }}
</head>
<body>
{{ block "content" . }}{{ end }}
<p style="font-style:italic; margin-top:2em">- git-credential-oauth-generic {{ .Version }}</p>
</body>
</html>
{{- end }}
